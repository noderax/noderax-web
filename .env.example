# Required: backend base origin used by Next server routes
# (/auth/login, /users/me, /nodes, /tasks, /events, /metrics)
NODERAX_API_URL=http://localhost:3000

# Optional: client-side fallback for realtime/api origin resolution
NEXT_PUBLIC_NODERAX_API_URL=http://localhost:3000

# Optional: Socket.IO base origin; if omitted, frontend falls back to
# NEXT_PUBLIC_NODERAX_API_URL. The frontend appends /realtime automatically.
NEXT_PUBLIC_NODERAX_WS_URL=http://localhost:3000
